#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

NAME="frps"
BIN="/usr/bin/frps"
CONFIG_FOLDER="/var/etc/$NAME"

_append_opt() {
	local file="$1"
	shift

	local key value
	for key in "$@"; do
		eval "value=\${$key}"
		[ -n "$value" ] || continue

		if printf '%s' "$key" | grep -qE 'addr|ip' && printf '%s' "$value" | grep -q ':'; then
			value="[$value]"
		fi

		printf '%s = %s\n' "$key" "$value" >> "$file"
	done
}

_append_common() {
	local section="$1"
	local file="$2"

	config_get bind_addr "$section" bind_addr
	config_get bind_port "$section" bind_port
	config_get bind_udp_port "$section" bind_udp_port
	config_get kcp_bind_port "$section" kcp_bind_port
	config_get quic_bind_port "$section" quic_bind_port
	config_get proxy_bind_addr "$section" proxy_bind_addr
	config_get vhost_http_port "$section" vhost_http_port
	config_get vhost_https_port "$section" vhost_https_port
	config_get vhost_http_timeout "$section" vhost_http_timeout
	config_get dashboard_addr "$section" dashboard_addr
	config_get dashboard_port "$section" dashboard_port
	config_get dashboard_user "$section" dashboard_user
	config_get dashboard_pwd "$section" dashboard_pwd
	config_get dashboard_tls_mode "$section" dashboard_tls_mode
	config_get dashboard_tls_cert_file "$section" dashboard_tls_cert_file
	config_get dashboard_tls_key_file "$section" dashboard_tls_key_file
	config_get assets_dir "$section" assets_dir
	config_get log_file "$section" log_file
	config_get log_level "$section" log_level
	config_get log_max_days "$section" log_max_days
	config_get disable_log_color "$section" disable_log_color
	config_get token "$section" token
	config_get subdomain_host "$section" subdomain_host
	config_get tcp_mux "$section" tcp_mux
	config_get custom_404_page "$section" custom_404_page
	config_get allow_ports "$section" allow_ports
	config_get max_ports_per_client "$section" max_ports_per_client
	config_get heartbeat_timeout "$section" heartbeat_timeout

	_append_opt "$file" \
		bind_addr bind_port bind_udp_port kcp_bind_port quic_bind_port \
		proxy_bind_addr vhost_http_port vhost_https_port vhost_http_timeout \
		dashboard_addr dashboard_port dashboard_user dashboard_pwd \
		dashboard_tls_mode dashboard_tls_cert_file dashboard_tls_key_file \
		assets_dir log_file log_level log_max_days disable_log_color token \
		subdomain_host tcp_mux custom_404_page allow_ports \
		max_ports_per_client heartbeat_timeout
}

_load_env() {
	local env="$1"
	[ -n "$env" ] || return 0
	procd_append_param env "$env"
}

_create_config() {
	local out="$1"
	local tmp
	tmp="$(mktemp /tmp/frps-XXXXXX)"

	echo "[common]" > "$tmp"
	_append_common "common" "$tmp"

	sed '/^$/d' "$tmp" > "$out"
	rm -f "$tmp"
}

start_service() {
	config_load frps
	config_get_bool enabled common enabled 0
	[ "$enabled" = "1" ] || return 0
	test -d "$CONFIG_FOLDER" || mkdir -p "$CONFIG_FOLDER"

	local config_file="$CONFIG_FOLDER/frps.ini"
	_create_config "$config_file"

	procd_open_instance "$NAME"
	procd_set_param command "$BIN" -c "$config_file"
	procd_set_param file "$config_file"

	config_get_bool stdout main stdout 0
	config_get_bool stderr main stderr 0
	config_get user main user
	config_get group main group
	config_get_bool respawn main respawn 1

	[ "$stdout" = "1" ] && procd_set_param stdout 1
	[ "$stderr" = "1" ] && procd_set_param stderr 1
	[ -n "$user" ] && procd_set_param user "$user"
	[ -n "$group" ] && procd_set_param group "$group"
	[ "$respawn" = "1" ] && procd_set_param respawn

	config_list_foreach main env _load_env
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger frps
}
