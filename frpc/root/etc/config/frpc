config conf 'common'
	option enabled 'false'
	option server_addr '127.0.0.1'
	option server_port '7000'
	option http_proxy ''
	option log_file ''
	option log_level 'info'
	option log_max_days '0'
	option disable_log_color 'false'
	option auth_method 'token'
	option token ''
	option oidc_client_id ''
	option oidc_client_secret ''
	option oidc_audience ''
	option oidc_token_endpoint_url ''
	option admin_addr '127.0.0.1'
	option admin_port '7400'
	option admin_user 'admin'
	option admin_pwd 'admin'
	option assets_dir ''
	option tcp_mux 'true'
	option user ''
	option login_fail_exit 'true'
	option protocol 'tcp'
	option tls_enable 'false'
	option heartbeat_interval '30'
	option heartbeat_timeout '90'

config init 'main'
	option stdout '0'
	option stderr '0'
	option user ''
	option group ''
	option respawn '1'

config conf 'ssh_proxy'
	option name 'ssh'
	option type 'tcp'
	option local_ip '127.0.0.1'
	option local_port '22'
	option remote_port '6000'
